<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="true" />
    <security>
      <requestFiltering>
        <!-- 550 MiB: 20 × 25 MiB files plus multipart overhead. -->
        <requestLimits maxAllowedContentLength="576716800" />
      </requestFiltering>
    </security>
    <rewrite>
      <rules>
        <rule name="PhD Atlas reverse proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4317/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
