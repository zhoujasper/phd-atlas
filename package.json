{
  "name": "phd-atlas",
  "private": true,
  "version": "0.1.0-beta.2",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node tools/start-server.mjs",
    "dev:full": "concurrently -k \"node tools/start-server.mjs\" \"node tools/wait-for-api.mjs && vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build && node tools/stamp-service-worker.mjs",
    "lint": "oxlint",
    "i18n:check": "node tools/check-i18n.mjs && node tools/check-ui-i18n.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "start": "node tools/start-server.mjs",
    "build:update-package": "node tools/build-update-package.mjs",
    "release:notes:check": "node tools/extract-release-notes.mjs --check",
    "verify:discover-adapters": "node tools/verify-discover-school-adapters.mjs",
    "verify:discover-adapters:live": "node tools/verify-discover-school-adapters.mjs --live",
    "seed:stress": "node tools/seed-stress-applications.mjs",
    "qa:stress": "node tools/qa-stress.mjs"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.2.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/code": "^0.47.0",
    "@lexical/html": "^0.47.0",
    "@lexical/link": "^0.47.0",
    "@lexical/list": "^0.47.0",
    "@lexical/markdown": "^0.47.0",
    "@lexical/react": "^0.47.0",
    "@lexical/rich-text": "^0.47.0",
    "@lexical/selection": "^0.47.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "docx-preview": "^0.3.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.3",
    "lexical": "^0.47.0",
    "lucide-react": "^1.22.0",
    "mailparser": "^3.9.12",
    "morgan": "^1.10.1",
    "mssql": "^11.0.1",
    "multer": "^2.0.2",
    "mysql2": "^3.23.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.17.2",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tar-fs": "^2.1.5",
    "web-push": "^3.6.7",
    "ws": "^8.21.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
