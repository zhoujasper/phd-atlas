# ───────────────────────────────────────────
# PhD Atlas — Minimal production config
# ───────────────────────────────────────────
# Only DOMAIN is required. Secrets are auto-generated on first boot
# and persisted to storage/bootstrap-secrets.json.
#
# Docker one-liner:
#   docker run -d --name phd-atlas \
#     -e DOMAIN="https://phd.example.com" \
#     -v phd-atlas-data:/app/storage \
#     -p 127.0.0.1:4317:4317 \
#     --restart unless-stopped \
#     ghcr.io/zhoujasper/phd-atlas:latest

# Your public HTTPS domain (required)
DOMAIN=https://phd.example.com

# Auto-derived from DOMAIN unless overridden:
# BASE_URL=https://phd.example.com
# CORS_ORIGIN=https://phd.example.com
# ALLOWED_HOSTS=phd.example.com

# ───────────────────────────────────────────
# Optional overrides
# ───────────────────────────────────────────

# Server port (default: 4317)
# PORT=4317

# Docker host port mapping (compose only)
# APP_PORT=4317

# Proxy trust setting (default: false)
# TRUST_PROXY=loopback

# Pin a specific image tag for reproducible deployments
# PHD_ATLAS_IMAGE=ghcr.io/zhoujasper/phd-atlas:latest

# ───────────────────────────────────────────
# Secrets (auto-generated — override only if migrating an existing install)
# ───────────────────────────────────────────
# JWT_SECRET=
# SETTINGS_ENCRYPTION_KEY=

# ───────────────────────────────────────────
# Optional: custom CA certificates for private databases/mail servers
# NODE_EXTRA_CA_CERTS=/app/storage/certs/private-ca.pem

# Optional: CJK PDF font paths
# PHD_ATLAS_PDF_FONT=
# PHD_ATLAS_PDF_FONT_BOLD=
