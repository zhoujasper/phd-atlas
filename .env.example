# Required in production
NODE_ENV=production
PORT=4317
BASE_URL=https://phd.example.com
CORS_ORIGIN=https://phd.example.com
ALLOWED_HOSTS=phd.example.com
TRUST_PROXY=loopback

# Generate independently, for example:
# node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-at-least-32-random-characters
SETTINGS_ENCRYPTION_KEY=replace-with-at-least-16-random-characters

# Private source edition only. The public edition ignores these values and uses
# the one-time /admin setup wizard instead.
BOOTSTRAP_USER_EMAIL=owner@example.com
BOOTSTRAP_USER_PASSWORD=replace-with-a-unique-strong-password
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-another-unique-strong-password

# Optional web-push keys. Leave all three blank to let the app persist a local key pair.
PUSH_VAPID_SUBJECT=mailto:admin@example.com
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# Optional PDF font paths for full CJK coverage.
PHD_ATLAS_PDF_FONT=
PHD_ATLAS_PDF_FONT_BOLD=
